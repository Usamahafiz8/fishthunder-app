# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=https://localhost:3001
FRONTEND_URL=https://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fishthunder_dev
DB_USER=
DB_PASSWORD=
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=14d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_TTL=60
AUTH_RATE_LIMIT_MAX=10

# ── Password Reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRY_MINUTES=60

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@fishthunder.com
MAIL_FROM_NAME=FishThunder

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
